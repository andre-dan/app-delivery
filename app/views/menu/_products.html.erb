<%# Partial renderizado dentro do turbo_frame "products".
    Recebe: products (ActiveRecord::Relation) %>

<% is_dinner = current_theme == "theme-dinner" %>

<% if products.empty? %>
  <div class="flex flex-col items-center justify-center gap-4 py-24 text-center">
    <span class="text-6xl">🕐</span>
    <p class="text-lg font-bold <%= is_dinner ? 'text-zinc-400' : 'text-orange-700' %>">
      Nenhum produto disponível agora.
    </p>
    <p class="text-sm <%= is_dinner ? 'text-zinc-500' : 'text-orange-400' %>">
      Almoço: 08:00 – 15:00 &nbsp;·&nbsp; Jantar: 18:00 – 23:00
    </p>
  </div>

<% else %>
  <ul class="grid grid-cols-1 gap-3 lg:grid-cols-3">
    <% products.each do |product| %>

      <%# Mobile: card horizontal (image left). Desktop: card vertical (image top) %>
      <li class="flex gap-0 overflow-hidden rounded-2xl shadow-sm transition-shadow hover:shadow-md
                 <%= is_dinner ? 'bg-zinc-800' : 'bg-white' %>">

        <%# ── FOTO ── %>
        <img src="<%= product_image_url(product) %>"
             alt="<%= product.name %>"
             class="h-28 w-28 shrink-0 object-cover
                    rounded-l-2xl
                    lg:h-44 lg:w-full lg:rounded-none lg:rounded-t-2xl"
             loading="lazy">

        <%# ── CONTEÚDO ── %>
        <div class="flex flex-1 flex-col justify-between p-3 lg:p-4">
          <div>
            <% unless product.both? %>
              <span class="mb-1 inline-block rounded-full px-2 py-0.5 text-xs font-bold
                           <%= product.lunch? ? 'bg-amber-100 text-orange-700' : 'bg-red-900/60 text-red-300' %>">
                <%= product.lunch? ? "Almoço" : "Jantar" %>
              </span>
            <% end %>

            <h3 class="text-sm font-bold leading-snug line-clamp-2 lg:text-base
                       <%= is_dinner ? 'text-zinc-100' : 'text-orange-900' %>">
              <%= product.name %>
            </h3>

            <% if product.description.present? %>
              <p class="mt-0.5 line-clamp-2 text-xs leading-relaxed opacity-60 lg:text-sm">
                <%= product.description %>
              </p>
            <% end %>
          </div>

          <%# ── PREÇO + BOTÃO + ── %>
          <div class="mt-3 flex items-center justify-between">
            <span class="text-base font-extrabold lg:text-lg
                         <%= is_dinner ? 'text-red-400' : 'text-orange-600' %>">
              <%= number_to_currency(product.price, unit: "R$", separator: ",", delimiter: ".") %>
            </span>

            <button data-action="cart#add"
                    data-cart-name-param="<%= product.name %>"
                    data-cart-price-param="<%= product.price %>"
                    class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full
                           text-xl font-bold text-white shadow
                           transition-transform active:scale-90
                           <%= is_dinner ? 'bg-red-700 hover:bg-red-600' : 'bg-orange-600 hover:bg-orange-500' %>">
              +
            </button>
          </div>
        </div>

      </li>
    <% end %>
  </ul>
<% end %>
